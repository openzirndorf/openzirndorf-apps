{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@openzirndorf/brand/*": ["packages/brand/src/assets/*"],
      "@openzirndorf/garagen-flohmarkt-api": ["packages/trpc/garagen-flohmarkt/src/index.ts"],
      "@openzirndorf/ui": ["packages/ui/src/index.ts"],
      "@openzirndorf/ui/*": ["packages/ui/src/*"]
    }
  }
}
